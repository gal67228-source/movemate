rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function tripDoc(tripId) {
      return get(
        /databases/$(database)/documents/trips/$(tripId)
      );
    }

    function isOwner(tripId) {
      return signedIn()
        && request.auth.uid
          == tripDoc(tripId).data.ownerUserId;
    }

    function isMember(tripId) {
      return signedIn()
        && request.auth.uid
          in tripDoc(tripId).data.memberIds;
    }

    function isEditor(tripId) {
      return signedIn()
        && request.auth.uid
          in tripDoc(tripId).data.editorIds;
    }

    match /trips/{tripId} {
      allow create: if signedIn()
        && request.resource.data.ownerUserId
          == request.auth.uid;

      allow read: if isMember(tripId);

      allow update: if isOwner(tripId)
        || (
          isEditor(tripId)
          && request.resource.data.ownerUserId
            == resource.data.ownerUserId
          && request.resource.data.memberIds
            == resource.data.memberIds
          && request.resource.data.editorIds
            == resource.data.editorIds
        )
        || (
          signedIn()
          && request.auth.uid
            in request.resource.data.memberIds
          && !(request.auth.uid
            in resource.data.memberIds)
          && request.resource.data.ownerUserId
            == resource.data.ownerUserId
        );

      allow delete: if isOwner(tripId);

      match /members/{memberId} {
        allow read: if isMember(tripId);
        allow create, update, delete:
          if isOwner(tripId)
          || (
            signedIn()
            && memberId == request.auth.uid
          );
      }

      match /activityFeed/{eventId} {
        allow read: if isMember(tripId);
        allow create: if isEditor(tripId);
        allow update, delete: if false;
      }

      match /{collectionName}/{documentId} {
        allow read: if isMember(tripId);
        allow create, update, delete:
          if isEditor(tripId);
      }
    }

    match /tripInvites/{code} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.createdBy
          == request.auth.uid;

      allow update: if signedIn()
        && (
          resource.data.createdBy
            == request.auth.uid
          || request.resource.data.acceptedBy
            == request.auth.uid
          || request.resource.data.declinedBy
            == request.auth.uid
        );

      allow delete: if signedIn()
        && resource.data.createdBy
          == request.auth.uid;
    }
  }
}
