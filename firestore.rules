rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(moveId) {
      return signedIn() &&
        get(/databases/$(database)/documents/moves/$(moveId)).data.ownerUid == request.auth.uid;
    }

    function isMember(moveId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/moves/$(moveId)/members/$(request.auth.uid));
    }

    function canAccess(moveId) {
      return isOwner(moveId) || isMember(moveId);
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && request.auth.uid == userId;
    }

    match /moves/{moveId} {
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read: if canAccess(moveId);
      allow update, delete: if isOwner(moveId);

      match /state/{stateKey} {
        allow read, write: if canAccess(moveId);
      }

      match /members/{memberId} {
        allow read: if canAccess(moveId);
        allow delete: if isOwner(moveId) || request.auth.uid == memberId;
        allow create: if signedIn() && request.auth.uid == memberId &&
          request.resource.data.uid == request.auth.uid &&
          exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)) &&
          get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.moveId == moveId &&
          get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.active == true &&
          get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode)).data.expiresAt > request.time;
        allow update: if false;
      }
    }

    match /invites/{code} {
      allow create: if signedIn() &&
        request.resource.data.ownerUid == request.auth.uid &&
        isOwner(request.resource.data.moveId);
      allow read: if signedIn();
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }
  }
}
